---
// Psychology Today logo downloaded to /public/assets/badges/psychology-today-logo.png
// AAMFT logo: styled text badge (logo not publicly accessible)
// Instagram + YouTube: inline SVGs
---

<!-- ── Credentials ─────────────────────────────────────────── -->
<section class="py-10 border-t border-border bg-background">
  <div class="container max-w-4xl">
    <p class="text-xs uppercase tracking-widest text-muted-foreground text-center mb-6">
      Verified &amp; Credentialed
    </p>
    <div class="flex flex-wrap justify-center items-center gap-6">

      <!-- Psychology Today -->
      <a
        href="https://www.psychologytoday.com/us/therapists/david-karol-gore-atlanta-ga/34127"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col items-center gap-1.5 opacity-75 hover:opacity-100 transition-opacity"
        aria-label="Verified by Psychology Today"
      >
        <img
          src="/assets/badges/psychology-today-logo.png"
          alt="Psychology Today"
          class="h-8 w-auto"
          loading="lazy"
        />
        <span class="text-[10px] uppercase tracking-widest text-muted-foreground group-hover:text-foreground transition-colors">
          Verified Therapist
        </span>
      </a>

      <div class="w-px h-10 bg-border hidden sm:block"></div>

      <!-- AAMFT Clinical Fellow -->
      <a
        href="https://www.aamft.org"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col items-center gap-1.5 opacity-75 hover:opacity-100 transition-opacity"
        aria-label="AAMFT Clinical Fellow"
      >
        <div class="flex items-center gap-2 px-3 py-1.5 rounded border border-[#1a3a6b]/30 bg-[#1a3a6b]/5 group-hover:border-[#1a3a6b]/60 transition-colors">
          <svg class="h-4 w-4 text-[#1a3a6b] flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2L3 7v10l9 5 9-5V7L12 2zm0 2.18L19 8v8l-7 3.88L5 16V8l7-3.82z"/>
          </svg>
          <span class="text-sm font-semibold text-[#1a3a6b] tracking-wide">AAMFT</span>
        </div>
        <span class="text-[10px] uppercase tracking-widest text-muted-foreground group-hover:text-foreground transition-colors">
          Clinical Fellow
        </span>
      </a>

    </div>
  </div>
</section>

<!-- ── Social Channels ─────────────────────────────────────── -->
<section class="py-10 bg-secondary">
  <div class="container max-w-4xl">
    <p class="text-xs uppercase tracking-widest text-muted-foreground text-center mb-6">
      Follow Along
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-stretch max-w-2xl mx-auto">

      <!-- Instagram -->
      <a
        href="https://www.instagram.com/the.cynical.psychologist/"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex-1 flex items-center gap-4 rounded-xl p-5 border border-border bg-card hover:border-pink-300 hover:shadow-md transition-all"
      >
        <!-- Instagram gradient icon -->
        <div class="flex-shrink-0 w-11 h-11 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);">
          <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="font-semibold text-foreground text-sm group-hover:text-pink-600 transition-colors">
            Over 1M views on Instagram.
          </p>
          <p class="text-xs text-muted-foreground mt-0.5">
            Turns out people like being told the truth.
          </p>
          <p class="text-xs text-muted-foreground mt-1 font-medium">
            @The.Cynical.Psychologist →
          </p>
        </div>
      </a>

      <!-- YouTube -->
      <a
        href="https://www.youtube.com/@the.cynical.psychologist"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex-1 flex items-center gap-4 rounded-xl p-5 border border-border bg-card hover:border-red-300 hover:shadow-md transition-all"
      >
        <!-- YouTube icon -->
        <div class="flex-shrink-0 w-11 h-11 rounded-xl bg-[#FF0000] flex items-center justify-center">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="white">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
        </div>
        <div class="min-w-0">
          <p class="font-semibold text-foreground text-sm group-hover:text-red-600 transition-colors">
            New videos on YouTube.
          </p>
          <p class="text-xs text-muted-foreground mt-0.5">
            Short takes on therapy, parenting, and real life.
          </p>
          <p class="text-xs text-muted-foreground mt-1 font-medium">
            @The.Cynical.Psychologist →
          </p>
        </div>
      </a>

    </div>
  </div>
</section>
