---
const GA4_ID = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID;
const ADS_ID = import.meta.env.PUBLIC_GOOGLE_ADS_ID;
const ADS_LABEL = import.meta.env.PUBLIC_GOOGLE_ADS_CONVERSION_LABEL;
const enabled = Boolean(GA4_ID || ADS_ID);
---
{enabled && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID || ADS_ID}`}></script>
    <script is:inline define:vars={{ GA4_ID, ADS_ID, ADS_LABEL }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('js', new Date());
      if (GA4_ID) gtag('config', GA4_ID, { send_page_view: true });
      if (ADS_ID) gtag('config', ADS_ID);

      // Delegate click tracking for any element with data-gtag-event
      document.addEventListener('click', function (e) {
        const el = e.target && e.target.closest && e.target.closest('[data-gtag-event]');
        if (!el) return;
        const eventName = el.getAttribute('data-gtag-event');
        const source = el.getAttribute('data-gtag-source') || 'unknown';
        gtag('event', eventName, { source: source });
        if (ADS_ID && ADS_LABEL && eventName === 'consultation_request') {
          gtag('event', 'conversion', { send_to: `${ADS_ID}/${ADS_LABEL}` });
        }
      });
    </script>
  </>
)}
