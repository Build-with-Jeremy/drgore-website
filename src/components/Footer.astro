---
const footerLinks = [
  { label: 'Home', path: '/' },
  { label: 'Biography', path: '/biography' },
  { label: 'About My Practice', path: '/about' },
  { label: "FAQ's", path: '/faqs' },
  { label: 'Articles', path: '/articles' },
  { label: 'Links', path: '/links' },
  { label: 'Blog', path: '/blog' },
  { label: 'Contact', path: '/contact' },
  { label: 'Privacy Policy', path: '/privacy' },
];
---
<footer class="bg-foreground text-primary-foreground">
  <div class="container py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="font-display text-xl font-semibold mb-4 text-left">
          Dr. David Karol Gore — Atlanta Adult, Teen and Child Psychologist, and Addiction/Alcoholism Expert
        </h3>
        <p class="text-primary-foreground/70 text-sm leading-relaxed text-justify">
          Helping individuals, couples, and families navigate life's challenges through
          expert psychotherapy, child and adolescent counseling, and personalized treatment plans.
        </p>
      </div>

      <div>
        <h4 class="font-display text-lg font-semibold mb-4">Quick Links</h4>
        <nav class="flex flex-col gap-2">
          {footerLinks.map((link) => (
            <a
              href={link.path}
              class="text-primary-foreground/70 hover:text-primary-foreground text-sm transition-colors"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <div>
        <h4 class="font-display text-lg font-semibold mb-4">Contact</h4>
        <address class="text-primary-foreground/70 text-sm not-italic leading-relaxed space-y-2">
          <p>6065 Lake Forrest Drive, Suite 250</p>
          <p>Atlanta, GA 30328</p>
          <p>
            Phone:{' '}
            <a href="tel:+14042374300" class="hover:text-primary-foreground transition-colors">
              (404) 237-4300
            </a>
          </p>
          <p>
            Email:{' '}
            <a href="mailto:dave@drgore.com" class="hover:text-primary-foreground transition-colors">
              dave@drgore.com
            </a>
          </p>
        </address>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-primary-foreground/20 text-center text-xs text-primary-foreground/50">
      <p>© {new Date().getFullYear()} Dr. Gore Therapy. All rights reserved.</p>
      <p class="mt-1">Atlanta Family Therapist · Atlanta Substance Abuse Addiction Treatment</p>
    </div>
  </div>
</footer>
