---
import { getProductBySlug } from '../data/goreProducts';
import AddToCartButton from './AddToCartButton';

interface Props {
  slug: string;
  variant?: 'banner' | 'card' | 'inline-mini';
  kicker?: string;
  headline?: string;
  body?: string;
}

const {
  slug,
  variant = 'card',
  kicker,
  headline,
  body,
} = Astro.props as Props;

const product = getProductBySlug(slug);
if (!product) {
  throw new Error(`StoreCallout: unknown product slug "${slug}"`);
}
---
{variant === 'banner' && (
  <section class="relative overflow-hidden bg-foreground text-background py-14 md:py-16">
    <div
      class="absolute inset-0 opacity-[0.06] pointer-events-none"
      style="background-image: repeating-linear-gradient(0deg, #ffffff 0, #ffffff 1px, transparent 1px, transparent 4px);"
    />
    <div class="relative container max-w-5xl">
      <div class="grid md:grid-cols-[auto_1fr] gap-8 md:gap-12 items-center">
        <div class="relative mx-auto md:mx-0 w-48 md:w-56 aspect-[4/5] bg-background p-2 pb-5 shadow-2xl" style="transform: rotate(-4deg);">
          <img
            src={product.image}
            alt={product.title}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="text-center md:text-left">
          <p class="font-display italic text-accent text-sm md:text-base mb-2">
            {kicker ?? 'A word from The Gore Store'}
          </p>
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-4">
            {headline ?? 'Prefer a product to a process?'}
          </h2>
          <p class="text-base md:text-lg text-background/80 leading-relaxed mb-6 max-w-xl mx-auto md:mx-0">
            {body ?? "Dr. Gore's also got a store."}
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start items-center">
            <a
              href="/store"
              class="inline-flex items-center gap-2 bg-accent text-accent-foreground hover:bg-accent/90 font-bold px-6 py-3 rounded-md transition-colors text-sm uppercase tracking-wider"
            >
              Visit The Gore Store
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
              </svg>
            </a>
            <AddToCartButton
              client:load
              slug={product.slug}
              label={`Add ${product.title.replace(/^"|"$/g, '').split(' ').slice(0, 3).join(' ')}… for ${product.price}`}
              variant="ghost"
              className="!border-background/30 !text-background hover:!bg-background/10"
            />
          </div>
        </div>
      </div>
    </div>
  </section>
)}

{variant === 'card' && (
  <aside class="border rounded-xl bg-card overflow-hidden shadow-sm my-10">
    <div class="grid md:grid-cols-[200px_1fr] gap-6 items-stretch">
      <img
        src={product.image}
        alt={product.title}
        class="w-full h-48 md:h-full object-cover"
        loading="lazy"
      />
      <div class="p-6 md:p-7 flex flex-col">
        <p class="text-xs uppercase tracking-widest text-accent font-bold mb-2">
          {kicker ?? 'Featured from The Gore Store'}
        </p>
        <h3 class="font-display text-xl md:text-2xl font-bold text-foreground leading-snug mb-2">
          {headline ?? product.title}
        </h3>
        <p class="text-sm text-muted-foreground leading-relaxed mb-4 flex-1">
          {body ?? product.description}
        </p>
        <div class="flex flex-wrap items-center gap-3 mt-auto">
          <span class="font-bold text-lg text-primary">{product.price}</span>
          <AddToCartButton client:load slug={product.slug} variant="primary" />
          <a href="/store" class="text-sm text-primary font-semibold hover:underline">
            Browse the store →
          </a>
        </div>
      </div>
    </div>
  </aside>
)}

{variant === 'inline-mini' && (
  <aside class="border-l-4 border-accent bg-muted/30 rounded-r-lg p-4 my-6">
    <p class="text-[0.65rem] uppercase tracking-widest text-accent font-bold mb-2">
      {kicker ?? 'Available now at The Gore Store'}
    </p>
    <div class="flex items-center gap-4">
      <img
        src={product.image}
        alt={product.title}
        class="w-16 h-16 object-cover rounded-md flex-shrink-0"
        loading="lazy"
      />
      <div class="flex-1 min-w-0">
        <p class="font-display font-semibold text-sm text-foreground leading-snug line-clamp-2">
          {headline ?? product.title}
        </p>
        <p class="text-xs text-muted-foreground mt-0.5">
          {product.price}
        </p>
      </div>
      <AddToCartButton client:load slug={product.slug} variant="mini" label="Add" />
    </div>
  </aside>
)}
