---
import Layout from '../layouts/Layout.astro';
import GoreStore from '../components/GoreStore';
import GoreStoreHero from '../components/GoreStoreHero';
import VideoChannelCallout from '../components/VideoChannelCallout.astro';
---
<Layout
  title="The Gore Store — Dr. David Karol Gore's Therapeutic Products"
  description="Browse The Gore Store — Dr. David Karol Gore's collection of therapeutic products. From an Atlanta family therapist with a sense of humor."
  canonical="https://drgore.com/store"
>
  <GoreStoreHero client:load />

  <section id="gore-store-grid" class="py-14 md:py-20 scroll-mt-20">
    <div class="container max-w-5xl">
      <GoreStore client:visible />

      <p class="mt-12 max-w-3xl text-sm italic text-muted-foreground leading-relaxed">
        A note from Dr. Gore: Some of these items may lead to the conclusion that I am
        minimizing or misunderstanding people’s pain, stuckness, and unhappiness. I am not.
        I care a great deal about my clients, and my number one goal is to help provide you
        and your loved ones a more fulfilling life.
      </p>
    </div>
  </section>

  <VideoChannelCallout />
</Layout>
