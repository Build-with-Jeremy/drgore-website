---
import Layout from '../layouts/Layout.astro';
import GoreStore from '../components/GoreStore';
import GoreStoreHero from '../components/GoreStoreHero';
---
<Layout
  title="The Gore Store — Dr. Gore's Therapeutic Products"
  description="Premium therapeutic products that are definitely, absolutely, 100% real. (They're not.) A humorous collection from Dr. David Gore, Atlanta family therapist."
  canonical="https://drgore.com/store"
>
  <GoreStoreHero client:load />

  <section id="gore-store-grid" class="py-14 md:py-20 scroll-mt-20">
    <div class="container max-w-6xl">
      <GoreStore client:visible />
    </div>
  </section>
</Layout>
