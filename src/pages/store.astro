---
import Layout from '../layouts/Layout.astro';
import GoreStore from '../components/GoreStore';
---
<Layout
  title="The Gore Store — Dr. Gore's Therapeutic Products"
  description="Premium therapeutic products that are definitely, absolutely, 100% real. (They're not.) A humorous collection from Dr. David Gore, Atlanta family therapist."
  canonical="https://drgore.com/store"
>
  <section class="relative">
    <img
      src="/assets/store/store-hero.jpg"
      alt="The Gore Store — colorful shopping bags"
      class="w-full h-64 md:h-80 object-cover"
    />
    <div class="absolute inset-0 bg-foreground/40 flex items-center justify-center">
      <div class="text-center">
        <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">
          The Gore Store
        </h1>
        <p class="text-white/90 text-lg max-w-2xl mx-auto px-4">
          Premium therapeutic products that are definitely, absolutely, 100% real.{' '}
          <span class="italic text-sm">(They're not.)</span>
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container max-w-5xl">
      <GoreStore client:visible />
    </div>
  </section>
</Layout>
