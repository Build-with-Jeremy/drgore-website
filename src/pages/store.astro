---
import Layout from '../layouts/Layout.astro';
import GoreStore from '../components/GoreStore';
import GoreStoreHero from '../components/GoreStoreHero';
---
<Layout
  title="The Gore Store — Dr. Gore's Therapeutic Products"
  description="Browse The Gore Store — Dr. David Gore's collection of therapeutic products. From an Atlanta family therapist with a sense of humor."
  canonical="https://drgore.com/store"
>
  <GoreStoreHero client:load />

  <section id="gore-store-grid" class="py-14 md:py-20 scroll-mt-20">
    <div class="container max-w-6xl">
      <div class="grid lg:grid-cols-[1fr_300px] gap-10 items-start">
        <div>
          <GoreStore client:visible />
        </div>

        {/* Sidebar — video from Dr. Gore's YouTube channel */}
        {/* Video: "Humblebrags Disguised as Complaints" (Humor + Self-Growth, non-marriage-specific) */}
        <aside class="lg:sticky lg:top-24 space-y-4">
          <div class="rounded-xl overflow-hidden shadow-md border border-border">
            <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;">
              <iframe
                src="https://www.youtube.com/embed/Rogx7Rz21gw"
                class="absolute top-0 left-0 w-full h-full"
                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                title="Humblebrags Disguised as Complaints — Dr. Gore"
                loading="lazy"
              ></iframe>
            </div>
            <div class="p-4 bg-card">
              <p class="text-sm font-semibold text-foreground leading-snug">
                Humblebrags Disguised as Complaints
              </p>
              <p class="text-xs text-muted-foreground mt-1">
                Sometimes complaining is just bragging. Dr. Gore explains.
              </p>
              <a
                href="/videos"
                class="inline-block text-xs text-primary font-semibold hover:underline mt-3"
              >
                More videos →
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
