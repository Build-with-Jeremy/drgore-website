---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    image: '/assets/services/child-psychology.jpg',
    title: 'Kids & Teens',
    description: "Kids don't get better in isolation. I'll see your child individually when it makes sense, but the real work happens when the whole family is in the room. Parents have more power to change a child's behavior than any therapist ever could. I'm going to ask you to use it.",
    tagline: 'When parents shift, children stabilize.',
  },
  {
    image: '/assets/services/family-therapy.jpg',
    title: 'Couples & Families',
    description: "If you're having the same fight on repeat and nothing ever resolves, that's not a communication problem. That's a refusal to change. I help couples and families shift the way they relate to each other. Somebody in the room has to go first.",
    tagline: 'Different input. Different output.',
  },
  {
    image: '/assets/services/addiction-recovery.jpg',
    title: 'Substance Abuse & Addiction',
    description: "Detox centers aren't the cure. They're the first step. Real recovery requires family involvement, accountability, and someone willing to push hard. I push hard. I believe in the 12-step approach and I'm not shy about saying so.",
    tagline: 'Recovery starts when someone decides the current path isn\'t working.',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "name": "Dr. David Karol Gore",
  "description": "Expert family therapy, child psychology, and substance abuse addiction treatment in Atlanta, Georgia.",
  "url": "https://drgore.com",
  "telephone": "+1-404-237-4300",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "6065 Lake Forrest Drive, Suite 250",
    "addressLocality": "Atlanta",
    "addressRegion": "GA",
    "postalCode": "30328",
    "addressCountry": "US"
  }
};
---
<Layout
  title="Dr. Gore — Atlanta Family Therapist, Psychologist & Addiction Specialist"
  description="Atlanta family therapist Dr. David Karol Gore has spent 42 years and 55,000+ hours helping people get unstuck. Therapy for depression, anxiety, kids, teens, couples, and addiction in Atlanta."
  canonical="https://drgore.com/"
  schema={schema}
>
  <!-- Hero -->
  <section class="w-full">
    <div class="relative w-full h-[60vh] md:h-[75vh] overflow-hidden">
      <img
        src="/assets/hero-family.jpg"
        alt="Family together — Dr. Gore Atlanta Family Therapist"
        style="object-position: 60% 20%; transform: scale(1.15); transform-origin: 60% 20%;"
        class="absolute inset-0 w-full h-full object-cover hidden md:block"
      />
      <img
        src="/assets/hero-family-mobile.png"
        alt="Family together — Dr. Gore Atlanta Family Therapist"
        class="absolute inset-0 w-full h-full object-cover object-top md:hidden"
      />
      <div class="absolute inset-0 flex items-end pl-24 md:pl-32 pb-20 md:pb-24">
        <p class="text-white font-display text-2xl md:text-4xl lg:text-5xl font-bold max-w-md leading-tight drop-shadow-lg">
          I can get you unstuck.
          <span class="block text-xl md:text-2xl lg:text-3xl mt-2 font-semibold">—Dr. Gore</span>
        </p>
      </div>
    </div>
  </section>

  <!-- Intro: Photo + Copy -->
  <section class="py-16 md:py-20 bg-background">
    <div class="container max-w-6xl">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
        <div class="order-2 md:order-1">
          <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-6 leading-tight">
            Atlanta Family Therapist, Psychologist &amp; Addiction Specialist
          </h1>
          <div class="space-y-4 text-muted-foreground leading-relaxed text-lg">
            <p>Are you feeling stuck?</p>
            <p>
              Not vaguely dissatisfied. Actually stuck. Same arguments. Same distance.
              Same patterns your parents had, now running on autopilot in your own house.
            </p>
            <p>
              I've spent 42 years and over 55,000 hours figuring out why people get stuck,
              and what it actually takes to change. Real change. The kind where you come back
              six months later and can't quite remember why everything felt so impossible.
            </p>
            <p>
              Most people don't need more time in therapy. They need someone willing to tell
              them the truth about what's actually happening. That's what I do.
            </p>
            <p class="font-semibold text-foreground">
              If nothing changes, nothing will change.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-4 mt-8">
            <a
              href="/contact"
              class="inline-block bg-primary text-primary-foreground hover:bg-primary/90 text-lg px-8 py-4 rounded-md font-semibold transition-colors"
            >
              Schedule a Consultation
            </a>
            <a
              href="/about"
              class="inline-block border border-border text-foreground hover:bg-secondary text-lg px-8 py-4 rounded-md font-semibold transition-colors"
            >
              About My Practice
            </a>
          </div>
        </div>
        <div class="order-1 md:order-2 flex justify-center md:justify-end">
          <img
            src="/assets/dr-gore.png"
            alt="Dr. David Karol Gore — Atlanta Family Therapist and Psychologist"
            class="w-72 md:w-full max-w-sm rounded-2xl shadow-xl object-cover object-top"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-secondary">
    <div class="container">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-center text-foreground mb-4">
        How I Can Help
      </h2>
      <p class="text-muted-foreground text-center max-w-2xl mx-auto mb-12">
        I'm a generalist, and proud of it. I treat kids, teens, couples, families, and individuals
        dealing with depression, anxiety, and addiction. Here's how I think about each.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {services.map((service) => (
          <div class="border-none shadow-lg hover:shadow-xl transition-shadow bg-card overflow-hidden rounded-lg">
            <img
              src={service.image}
              alt={service.title}
              class="w-full h-48 object-cover"
            />
            <div class="p-8">
              <h3 class="font-display text-xl font-semibold text-foreground mb-4">
                {service.title}
              </h3>
              <p class="text-muted-foreground leading-relaxed text-sm">
                {service.description}
              </p>
              {service.tagline && (
                <p class="font-display font-bold text-sm text-foreground mt-4 italic">
                  {service.tagline}
                </p>
              )}
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/about" class="text-primary font-semibold hover:underline">
          Read more about how I work →
        </a>
      </div>
    </div>
  </section>

  <!-- Video -->
  <section class="py-16 bg-background">
    <div class="container max-w-4xl text-center">
      <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground mb-4">
        See How I Think
      </h2>
      <p class="text-muted-foreground leading-relaxed max-w-2xl mx-auto mb-8">
        I've been posting videos for a while now. This one gets at something I believe
        pretty deeply about relationships and how we end up where we do.
        Watch it and see if you recognize yourself anywhere in it.
        Don't worry if you do — that's the point.
      </p>
      <div class="relative w-full rounded-xl shadow-lg overflow-hidden" style="padding: 56.25% 0 0 0; position: relative;">
        <iframe
          src="https://player.vimeo.com/video/1171891484?loop=1"
          class="absolute top-0 left-0 w-full h-full"
          frameborder="0"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          title="Dr. Gore - Family Therapy"
        ></iframe>
      </div>
      <p class="text-muted-foreground text-sm mt-4">
        More videos at <a href="https://www.youtube.com/@the.cynical.psychologist" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">@The.Cynical.Psychologist</a> on YouTube and Instagram.
      </p>
    </div>
  </section>

  <!-- Call me CTA -->
  <section class="py-20 bg-primary">
    <div class="container max-w-3xl text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-primary-foreground mb-6">
        Call me. I'll call you back.
      </h2>
      <div class="space-y-4 text-primary-foreground/90 text-lg max-w-xl mx-auto mb-10">
        <p>
          I return every call. Every one. Nine in the morning to midnight.
        </p>
        <p>
          That's not a marketing line. I've been doing it for 42 years.
          If I can't take you on, I'll tell you who can.
          Either way, you'll hear from me.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="tel:+14042374300"
          class="inline-block bg-accent text-accent-foreground hover:bg-accent/90 text-xl px-10 py-4 rounded-md font-bold transition-colors"
        >
          (404) 237-4300
        </a>
        <a
          href="/contact"
          class="inline-block border border-primary-foreground/40 text-primary-foreground hover:bg-primary-foreground/10 text-lg px-8 py-4 rounded-md font-semibold transition-colors"
        >
          Send a message instead
        </a>
      </div>
      <p class="text-primary-foreground/60 text-sm mt-8">
        Sandy Springs / Atlanta · 6065 Lake Forrest Drive, Suite 250
      </p>
    </div>
  </section>
</Layout>
