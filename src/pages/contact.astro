---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm';
import Testimonials from '../components/Testimonials.astro';
import TrustBadges from '../components/TrustBadges.astro';
---
<Layout
  title="Contact Dr. Gore — Atlanta Family Therapist"
  description="Reach Dr. David Karol Gore by phone or message. Atlanta family therapist serving adults, teens, and families. Call (404) 237-4300."
  canonical="https://drgore.com/contact"
>
  <section class="py-20">
    <div class="container max-w-5xl">
      <h1 class="font-display text-4xl font-bold text-foreground mb-8">Contact</h1>
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <!-- Contact Info -->
        <div class="space-y-8">
          <div>
            <h2 class="font-display text-2xl font-semibold text-foreground mb-4">
              Call Me to Start This Process
            </h2>
            <p class="text-muted-foreground mb-6">
              Call or send a message. I return every call, usually the same day.
              If we're not a good fit, I'll tell you that too, and point you toward someone who is.
            </p>
          </div>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <svg class="h-5 w-5 text-primary mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 10 19.79 19.79 0 0 1 1.65 1.4 2 2 0 0 1 3.6 0h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 7.91a16 16 0 0 0 6.07 6.07l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <div>
                <p class="font-medium text-foreground">Phone</p>
                <a href="tel:+14042374300" class="text-muted-foreground hover:text-primary transition-colors" data-gtag-event="phone_click" data-gtag-source="contact_page">
                  (404) 237-4300
                </a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="h-5 w-5 text-primary mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <div>
                <p class="font-medium text-foreground">Email</p>
                <a href="mailto:dave@drgore.com" class="text-muted-foreground hover:text-primary transition-colors" data-gtag-event="email_click" data-gtag-source="contact_page">
                  dave@drgore.com
                </a>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <svg class="h-5 w-5 text-primary mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <div>
                <p class="font-medium text-foreground">Location</p>
                <p class="text-muted-foreground">6065 Lake Forrest Drive, Suite 250</p>
                <p class="text-muted-foreground">Atlanta, GA 30328</p>
              </div>
            </div>
          </div>
          <div class="bg-secondary rounded-xl p-6">
            <p class="text-sm text-muted-foreground italic">
              NOTE: There is currently a two to four week waiting period for new clients.
            </p>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-card rounded-xl border border-border p-8 shadow-sm">
          <h2 class="font-display text-xl font-semibold text-foreground mb-6">Send a Message</h2>
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>
  <TrustBadges />
  <Testimonials />
</Layout>
