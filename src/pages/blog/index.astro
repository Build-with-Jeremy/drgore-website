---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blogPosts';
---
<Layout
  title="Blog — Dr. Gore, Atlanta Family Therapist"
  description="Thoughts on therapy, connection, and the patterns we carry — by Dr. David Gore, Atlanta family therapist and psychologist."
  canonical="https://drgore.com/blog"
>
  <section class="py-16 bg-secondary">
    <div class="container max-w-5xl">
      <h1 class="font-display text-4xl font-bold text-foreground mb-4">
        Blog
      </h1>
      <p class="text-muted-foreground text-lg">
        Personal writing from someone who has spent 42 years listening. Some pieces are funny. Some are not. All of them are true.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="container max-w-5xl space-y-10">
      {blogPosts.map((post) => (
        <a
          href={`/blog/${post.slug}`}
          class="group block overflow-hidden rounded-xl border bg-card hover:shadow-lg transition-all hover:border-primary/30"
        >
          <div class="flex flex-col md:flex-row">
            <div class="md:w-2/5 aspect-[3/2] md:aspect-auto overflow-hidden bg-gradient-to-br from-secondary to-muted">
              <img
                src={post.thumbnail}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                onerror="this.style.display='none'"
              />
            </div>
            <div class="p-6 md:p-8 md:w-3/5 flex flex-col justify-center">
              <span class="text-xs text-muted-foreground/60 font-medium uppercase tracking-wider mb-2">
                {post.date}
              </span>
              <h2 class="font-display text-2xl font-bold text-foreground mb-3 group-hover:text-primary transition-colors">
                {post.title}
              </h2>
              <p class="text-muted-foreground leading-relaxed line-clamp-3">
                {post.summary}
              </p>
              <span class="mt-4 text-primary font-medium text-sm group-hover:underline">
                Read more →
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
